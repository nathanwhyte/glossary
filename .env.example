# Garage S3-compatible storage configuration
# Copy this file to .env and fill in your actual values

# Garage endpoint URL
# For Kubernetes cluster: http://garage.garage.svc.cluster.local:3900
# For local port-forward: http://localhost:3900
GARAGE_ENDPOINT=http://garage.garage.svc.cluster.local:3900

# Garage access key (S3 API key)
GARAGE_ACCESS_KEY=

# Garage secret key (S3 API secret)
GARAGE_SECRET_KEY=

# Garage region (default: garage)
GARAGE_REGION=garage
