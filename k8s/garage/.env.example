# Garage S3 Configuration
# Copy this file to .env and fill in your values
# The .env file is gitignored and will not be committed

# Garage S3 endpoint
# For cluster-internal access:
GARAGE_ENDPOINT=http://garage.garage.svc.cluster.local:3900
# For local access (with port-forward):
# GARAGE_ENDPOINT=http://localhost:3900

# Garage region
GARAGE_REGION=garage

# S3 Access credentials (create via: garage key new --name test-key)
# Leave empty for anonymous access (may fail for some operations)
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
